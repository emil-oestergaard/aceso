# Binaries
/aceso
/bin/
/dist/
/out/
*.exe
*.test
*.out

# Go workspace / cache
/vendor/
go.work
go.work.sum

# Local data — incidents are runtime state, never check them in
/data/
incidents.json
*.ndjson

# Env files (real values must never be committed)
.env
.env.*
!.env.example

# Pi-deploy operator configs (real values live outside the repo;
# only the *.example templates are committed). See docs/pi-deploy.md.
scripts/*.conf
scripts/templates/*.conf
!scripts/templates/*.conf.example

# Editor & OS clutter
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# Coverage
coverage.out
coverage.html
