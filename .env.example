# Aceso environment template.
#
# Copy to `.env` (gitignored) and fill in the values you actually use.
# Source of truth for the variable list is agent/config.go:loadConfig.
# Anything not set here falls back to the default shown next to it.

# --- Required ---------------------------------------------------------------

# Base URLs for the three observe-loop dependencies. No trailing slash.
# In production the monitoring stack lives on an external Docker network
# named "monitoring"; in dev (docker-compose.dev.yml) these resolve via
# the bridge network.
PROMETHEUS_URL=http://prometheus:9090
LOKI_URL=http://loki:3100

# Ollama is the primary LLM backend. In production we typically run
# Ollama on a Tailscale-reachable Raspberry Pi to keep the VPS small —
# point this at the Pi's Tailscale IP, e.g. http://100.x.x.x:11434.
OLLAMA_URL=http://ollama:11434

# --- LLM fallback chain (optional) ------------------------------------------

# Order in which backends are tried. First success wins; backends without
# credentials are skipped at startup with a log line.
# Default: ollama,deepseek,gemini
BACKEND_ORDER=ollama,deepseek,gemini

# Free-tier API keys for the fallback backends. Leave empty to skip the
# backend entirely; the chain still works with only Ollama configured.
# DeepSeek: https://platform.deepseek.com/api_keys
# Gemini:   https://aistudio.google.com/apikey
DEEPSEEK_API_KEY=
GEMINI_API_KEY=

# --- Tunables (optional) ----------------------------------------------------

# Any locally-pulled Ollama model. gemma2:2b fits a 4 GB VPS; on a 16 GB
# Pi you can comfortably run larger models.
OLLAMA_MODEL=gemma2:2b

# Cadence of the observe loop, in seconds.
POLL_INTERVAL_SECONDS=30

# Per-call timeout (Prometheus, Loki, every LLM backend). Ollama's first
# generation after a cold load can be slow — keep this generous.
HTTP_TIMEOUT_SECONDS=120

# Where the NDJSON incident log lives. /data is a named Docker volume in
# both compose files; use a host path for non-Docker dev runs.
INCIDENTS_PATH=/data/incidents.json
